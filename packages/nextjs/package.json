{
  "name": "@eventra/nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check-types": "tsc --noEmit --incremental",
    "dev": "next dev",
    "format": "prettier --write . '!(node_modules|.next)/**/*'",
    "lint": "next lint",
    "serve": "next start",
    "start": "next dev",
    "vercel": "vercel --build-env VERCEL_TELEMETRY_DISABLED=1",
    "vercel:login": "vercel login",
    "vercel:yolo": "vercel --build-env NEXT_PUBLIC_IGNORE_BUILD_ERROR=true --build-env VERCEL_TELEMETRY_DISABLED=1"
  },
  "dependencies": {
    "@heroicons/react": "~2.1.5",
    "ethers": "^6.17.0",
    "next": "^15.5.19",
    "react": "~19.2.3",
    "react-dom": "~19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.0.15",
    "@trivago/prettier-plugin-sort-imports": "~4.3.0",
    "@types/node": "~18.19.50",
    "@types/react": "~19.0.7",
    "autoprefixer": "~10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "~15.2.3",
    "eslint-config-prettier": "~10.1.1",
    "eslint-plugin-prettier": "~5.2.4",
    "postcss": "~8.4.45",
    "prettier": "~3.5.3",
    "tailwindcss": "4.1.3",
    "typescript": "~5.8.2",
    "vercel": "^54.14.2"
  }
}
