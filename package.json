{
  "name": "eventra",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "account": "npm run foundry:account",
    "account:generate": "npm run foundry:generate",
    "account:import": "npm run foundry:account-import",
    "account:reveal-pk": "npm run account:reveal-pk -w @eventra/foundry",
    "chain": "npm run foundry:chain",
    "compile": "npm run foundry:compile",
    "deploy": "npm run foundry:deploy",
    "flatten": "npm run foundry:flatten",
    "fork": "npm run foundry:fork",
    "format": "npm run next:format && npm run foundry:format",
    "foundry:account": "npm run account -w @eventra/foundry",
    "foundry:account-import": "npm run account:import -w @eventra/foundry",
    "foundry:chain": "npm run chain -w @eventra/foundry",
    "foundry:clean": "npm run clean -w @eventra/foundry",
    "foundry:compile": "npm run compile -w @eventra/foundry",
    "foundry:deploy": "npm run deploy -w @eventra/foundry",
    "foundry:flatten": "npm run flatten -w @eventra/foundry",
    "foundry:fork": "npm run fork -w @eventra/foundry",
    "foundry:format": "npm run format -w @eventra/foundry",
    "foundry:generate": "npm run account:generate -w @eventra/foundry",
    "foundry:lint": "npm run lint -w @eventra/foundry",
    "foundry:test": "npm run test -w @eventra/foundry",
    "foundry:verify": "npm run verify -w @eventra/foundry",
    "generate": "npm run foundry:generate",
    "lint": "npm run next:lint && npm run foundry:lint",
    "next:build": "npm run build -w @eventra/nextjs",
    "next:check-types": "npm run check-types -w @eventra/nextjs",
    "next:format": "npm run format -w @eventra/nextjs",
    "next:lint": "npm run lint -w @eventra/nextjs",
    "next:serve": "npm run serve -w @eventra/nextjs",
    "start": "npm run dev -w @eventra/nextjs",
    "test": "npm run foundry:test",
    "vercel": "npm run vercel -w @eventra/nextjs",
    "vercel:login": "npm run vercel:login -w @eventra/nextjs",
    "vercel:yolo": "npm run vercel:yolo -w @eventra/nextjs",
    "verify": "npm run foundry:verify"
  },
  "engines": {
    "node": ">=20.18.3"
  }
}
